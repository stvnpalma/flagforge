{
  "info": {
    "name": "FlagForge API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{bearerToken}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "https://bh78ow1udg.execute-api.us-east-1.amazonaws.com/prod",
      "type": "string"
    },
    {
      "key": "bearerToken",
      "value": "PASTE_YOUR_COGNITO_ID_TOKEN_HERE",
      "type": "string"
    },
    {
      "key": "projectId",
      "value": "",
      "type": "string"
    },
    {
      "key": "envId",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Projects",
      "item": [
        {
          "name": "Create Project",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/projects",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"My First Project\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "List Projects",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/projects"
          }
        },
        {
          "name": "Get Project",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/projects/{{projectId}}"
          }
        }
      ]
    },
    {
      "name": "Environments",
      "item": [
        {
          "name": "Create Environment",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/projects/{{projectId}}/environments",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Production\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "List Environments",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/projects/{{projectId}}/environments"
          }
        }
      ]
    },
    {
      "name": "Flags",
      "item": [
        {
          "name": "Create Flag",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/projects/{{projectId}}/flags",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"flagKey\": \"new-checkout-flow\",\n  \"name\": \"New checkout flow\",\n  \"description\": \"Rolls out the redesigned checkout\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "List Flags",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/projects/{{projectId}}/flags"
          }
        },
        {
          "name": "Get Flag",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/projects/{{projectId}}/flags/new-checkout-flow"
          }
        },
        {
          "name": "Set Flag State",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/projects/{{projectId}}/flags/new-checkout-flow/environments/{{envId}}",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"enabled\": true\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Get Flag State",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/projects/{{projectId}}/flags/new-checkout-flow/environments/{{envId}}"
          }
        }
      ]
    },
    {
      "name": "Evaluation",
      "item": [
        {
          "name": "Evaluate All Flags",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/projects/{{projectId}}/environments/{{envId}}/evaluate"
          }
        },
        {
          "name": "Evaluate Single Flag",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/projects/{{projectId}}/environments/{{envId}}/evaluate/dark-mode"
          }
        }
      ]
    },
    {
      "name": "API Keys",
      "item": [
        {
          "name": "Create API Key",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api-keys",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"keyName\": \"Development Key\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        }
      ]
    }
  ]
}
